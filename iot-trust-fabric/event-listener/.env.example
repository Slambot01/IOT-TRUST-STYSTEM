# ==============================================================================
# Environment Configuration for IoT Trust Event Listener
# ==============================================================================
# Copy this file to .env and adjust the values as needed.
# Usage: cp .env.example .env
# ==============================================================================

# WebSocket server port (clients connect here)
WS_PORT=8080

# Fabric channel name
CHANNEL_NAME=iot-channel

# Path to connection profile JSON
# Update this to the absolute path on your system
CONNECTION_PROFILE=../fabric-network/connection-profile.json

# Path to the filesystem wallet (stores enrolled identities)
WALLET_PATH=./wallet

# Admin identity label in the wallet
ADMIN_IDENTITY=admin
